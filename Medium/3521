WITH FrequentlyBoughtTogether AS (
    SELECT 
        p1.product_id AS product1_id,
        p2.product_id AS product2_id,
        COUNT(DISTINCT p1.user_id) AS customer_count
    FROM 
        ProductPurchases p1
    INNER JOIN 
        ProductPurchases p2 ON p1.user_id = p2.user_id
    WHERE 
        p1.product_id < p2.product_id
    GROUP BY 
        p1.product_id, p2.product_id
    HAVING 
        COUNT(DISTINCT p1.user_id) >= 3
)

SELECT 
    f.product1_id,
    f.product2_id,
    info1.category AS product1_category,
    info2.category AS product2_category,
    f.customer_count
FROM 
    FrequentlyBoughtTogether f
INNER JOIN 
    ProductInfo info1 ON f.product1_id = info1.product_id
INNER JOIN 
    ProductInfo info2 ON f.product2_id = info2.product_id
ORDER BY 
    f.customer_count DESC,
    f.product1_id ASC,
    f.product2_id ASC;
