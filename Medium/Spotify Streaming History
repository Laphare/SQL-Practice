WITH
weekly_count AS (SELECT user_id, song_id, COUNT(*) AS weekly_song_count
FROM songs_weekly
WHERE listen_time <= '2022/08/04 23:59:59'
GROUP BY user_id, song_id)

SELECT COALESCE(w.user_id, s.user_id),COALESCE(w.song_id, s.song_id),
COALESCE(w.weekly_song_count,0) + COALESCE(s.song_plays,0) AS song_plays
FROM weekly_count w 
FULL OUTER JOIN songs_history s 
ON s.user_id = w.user_id
AND s.song_id = w.song_id

ORDER BY song_plays DESC
