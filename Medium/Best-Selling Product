WITH 
rn_list AS (
SELECT DISTINCT p.category_name,p.product_name,
ROW_NUMBER()OVER(PARTITION BY p.category_name ORDER BY ps.sales_quantity DESC, ps.rating DESC) AS rn 
FROM product_sales ps 
INNER JOIN products p 
ON p.product_id = ps.product_id
)

SELECT category_name,product_name
FROM rn_list
WHERE rn = 1
ORDER BY category_name,product_name
