WITH
dedu_list AS (SELECT user_id,EXTRACT(MONTH FROM login_date) AS mth
FROM user_logins
GROUP BY user_id,EXTRACT(MONTH FROM login_date)
),

lag_list AS (SELECT *, 
LAG(mth)OVER(PARTITION BY user_id ORDER BY mth) AS pre_mth
FROM dedu_list),

cata_list AS (SELECT user_id,mth,
CASE WHEN pre_mth IS NULL OR mth-pre_mth != 1 THEN 1 END AS cata 
FROM lag_list)

SELECT mth,
SUM(cata) AS reactivated_users
FROM cata_list
WHERE cata IS NOT NULL 
GROUP BY mth
ORDER BY mth
