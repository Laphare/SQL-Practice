WITH
senior_manage AS (
SELECT DISTINCT manager_id
FROM employees
WHERE emp_id IN (SELECT DISTINCT manager_id FROM employees WHERE manager_id IS NOT NULL)
AND manager_id IS NOT NULL ),

too_senior_manage AS (
SELECT DISTINCT manager_id
FROM employees
WHERE emp_id IN (SELECT DISTINCT manager_id FROM senior_manage WHERE manager_id IS NOT NULL)
AND manager_id IS NOT NULL)

SELECT manager_name, COUNT (*) AS direct_reportees
FROM employees
WHERE manager_id IN (SELECT manager_id FROM senior_manage)
AND manager_id NOT IN (SELECT manager_id FROM too_senior_manage)
GROUP BY manager_name

ORDER BY direct_reportees DESC

