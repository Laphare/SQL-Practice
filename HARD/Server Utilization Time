WITH
start_date_list AS (SELECT server_id,status_time AS start_time,
ROW_NUMBER()OVER(PARTITION BY server_id ORDER BY status_time) as rn 
FROM server_utilization
WHERE session_status = 'start'),

stop_date_list AS (SELECT server_id,status_time AS stop_time,
ROW_NUMBER()OVER(PARTITION BY server_id ORDER BY status_time) as rn 
FROM server_utilization
WHERE session_status = 'stop')


SELECT 
SUM((EXTRACT(EPOCH FROM (sp.stop_time - st.start_time )) / 86400) :: INT)  AS total_uptime_days
FROM start_date_list st  
INNER JOIN stop_date_list sp 
ON st.server_id = sp.server_id
AND st.rn = sp.rn
