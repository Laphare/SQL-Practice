WITH DISTINCT_list AS (
SELECT DISTINCT record_date,user_id
FROM sf_events
),

rn_list AS (select *,
ROW_NUMBER()OVER(PARTITION BY user_id ORDER BY record_date) AS rn
from DISTINCT_list),

group_list AS (
SELECT user_id, record_date - rn * interval '1 days' AS date_a
FROM rn_list)

SELECT user_id
FROM group_list
GROUP BY user_id , date_a
HAVING COUNT(*) >= 3
